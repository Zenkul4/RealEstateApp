@model List<SaleTypeViewModel>
@{
    ViewData["Title"] = "Tipos de Venta";
}

<div class="container px-4 mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light">
        <div>
            <h2 class="fw-bold tracking-tight text-slate-dark m-0">Mantenimiento de Tipos de Venta</h2>
            <p class="text-muted m-0 fs-6">Administre las modalidades y tipos de operaciones comerciales para las propiedades.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn-brass shadow-sm">Crear nuevo tipo</a>
        </div>
    </div>

    <div class="architect-card">
        @if (Model == null || Model.Count == 0)
        {
            <div class="text-center py-5">
                <p class="text-muted fs-5 mb-0">No se encontraron tipos de venta registrados.</p>
                <p class="text-muted fs-6 mt-1">Haga clic en el botón superior para agregar una nueva modalidad comercial.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table-architect">
                    <thead>
                        <tr>
                            <th scope="col" style="width: 30%">Nombre</th>
                            <th scope="col" style="width: 50%">Descripción</th>
                            <th scope="col" class="text-end" style="width: 20%">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Name</td>
                                <td class="text-muted">@item.Description</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-outline-brass btn-sm px-3 py-1 me-2">Editar</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-outline-slate btn-sm px-3 py-1">Eliminar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
