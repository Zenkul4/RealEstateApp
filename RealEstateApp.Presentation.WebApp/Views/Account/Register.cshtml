@model RegisterViewModel
@using RealEstateApp.Core.Application.DTOs.Account
@{
    ViewData["Title"] = "Únete a RealEstateApp";
}

<section class="registration-shell">
    <header class="registration-heading">
        <span class="auth-eyebrow">Nueva membresía</span>
        <h1>Encuentra tu lugar.<br />O publica el próximo.</h1>
        <p>Crea una identidad verificada para guardar propiedades o administrar tus propios listados.</p>
    </header>

    <form asp-action="Register" method="post" enctype="multipart/form-data" class="registration-form">
        <div asp-validation-summary="ModelOnly" class="validation-panel registration-summary"></div>

        <fieldset class="account-selector">
            <legend>¿Cómo usarás RealEstateApp?</legend>
            <label class="role-card">
                <input asp-for="UserType" type="radio" value="@UserType.Client" />
                <span class="role-card__mark">C</span>
                <span><strong>Cliente</strong><small>Explora, guarda y presenta ofertas.</small></span>
            </label>
            <label class="role-card">
                <input asp-for="UserType" type="radio" value="@UserType.Agent" />
                <span class="role-card__mark">A</span>
                <span><strong>Agente</strong><small>Publica y gestiona propiedades.</small></span>
            </label>
            <span asp-validation-for="UserType"></span>
        </fieldset>

        <div class="form-section">
            <div class="form-section__title"><span>Identidad</span><p>Los datos que verán otros usuarios.</p></div>
            <div class="form-grid">
                <div class="field-group"><label asp-for="FirstName"></label><input asp-for="FirstName" /><span asp-validation-for="FirstName"></span></div>
                <div class="field-group"><label asp-for="LastName"></label><input asp-for="LastName" /><span asp-validation-for="LastName"></span></div>
                <div class="field-group"><label asp-for="Cedula"></label><input asp-for="Cedula" inputmode="numeric" /><span asp-validation-for="Cedula"></span></div>
                <div class="field-group"><label asp-for="Phone"></label><input asp-for="Phone" type="tel" /><span asp-validation-for="Phone"></span></div>
                <div class="field-group field-wide"><label asp-for="Photo"></label><input asp-for="Photo" type="file" accept=".jpg,.jpeg,.png,.webp" /><small>JPG, PNG o WEBP · máximo 2 MB</small><span asp-validation-for="Photo"></span></div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section__title"><span>Acceso</span><p>Credenciales únicas para proteger tu cuenta.</p></div>
            <div class="form-grid">
                <div class="field-group"><label asp-for="Email"></label><input asp-for="Email" autocomplete="email" /><span asp-validation-for="Email"></span></div>
                <div class="field-group"><label asp-for="UserName"></label><input asp-for="UserName" autocomplete="username" /><span asp-validation-for="UserName"></span></div>
                <div class="field-group"><label asp-for="Password"></label><input asp-for="Password" autocomplete="new-password" /><span asp-validation-for="Password"></span></div>
                <div class="field-group"><label asp-for="ConfirmPassword"></label><input asp-for="ConfirmPassword" autocomplete="new-password" /><span asp-validation-for="ConfirmPassword"></span></div>
            </div>
        </div>

        <div class="registration-actions">
            <p>Los clientes activan su cuenta por correo. Los agentes requieren aprobación administrativa.</p>
            <button type="submit" class="auth-primary">Crear mi cuenta <span aria-hidden="true">→</span></button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
