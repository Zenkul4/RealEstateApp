@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container px-4 py-5 my-5 text-center">
    <div class="architect-card p-5 mx-auto shadow-lg" style="max-width: 550px;">
        <div class="mb-4">
            <div class="bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                <span class="fw-bold font-monospace fs-1">!</span>
            </div>
        </div>

        <h2 class="fw-bold tracking-tight text-slate-dark text-uppercase mb-2">Acceso Restringido</h2>
        <p class="text-muted fs-6 mb-4">No tiene permisos suficientes para acceder a este recurso o funcionalidad del sistema.</p>

        <div class="border-top border-light pt-4 mt-2">
            @if (User.Identity?.IsAuthenticated == true)
            {
                if (User.IsInRole("Administrador") || User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index" class="btn-brass px-4 py-2 text-uppercase fs-8 tracking-wider">Ir al Panel de Administrador</a>
                }
                else if (User.IsInRole("Agente") || User.IsInRole("Agent"))
                {
                    <a asp-controller="Agent" asp-action="Index" class="btn-brass px-4 py-2 text-uppercase fs-8 tracking-wider">Ir a Mis Propiedades (Agente)</a>
                }
                else if (User.IsInRole("Cliente") || User.IsInRole("Client"))
                {
                    <a asp-controller="Home" asp-action="Index" class="btn-brass px-4 py-2 text-uppercase fs-8 tracking-wider">Ir al Buscador Principal</a>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index" class="btn-brass px-4 py-2 text-uppercase fs-8 tracking-wider">Volver al Inicio</a>
                }
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn-brass px-4 py-2 text-uppercase fs-8 tracking-wider">Iniciar Sesión</a>
            }
        </div>
    </div>
</div>
