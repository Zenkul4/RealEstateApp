@model List<RealEstateApp.Core.Application.ViewModels.Account.UserViewModel>
@{
    ViewData["Title"] = "Mantenimiento de Agentes";
}

<div class="container px-4 mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light">
        <div>
            <h2 class="fw-bold tracking-tight text-slate-dark m-0">Mantenimiento de Agentes</h2>
            <p class="text-muted m-0 fs-6">Administre las cuentas de los asesores inmobiliarios registrados en el sistema.</p>
        </div>
        <div class="bg-light px-3 py-2 border border-light">
            <span class="fs-7 text-uppercase tracking-wider fw-bold text-muted">Total Agentes:</span>
            <span class="fw-bold text-slate-dark fs-6 font-monospace">@Model.Count</span>
        </div>
    </div>

    <div class="architect-card">
        @if (Model == null || Model.Count == 0)
        {
            <div class="text-center py-5">
                <p class="text-muted fs-5 mb-0">No se encontraron agentes registrados en la base de datos.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table-architect">
                    <thead>
                        <tr>
                            <th scope="col" style="width: 30%">Asesor</th>
                            <th scope="col" style="width: 25%">Correo / Usuario</th>
                            <th scope="col" class="text-center" style="width: 20%">Inmuebles Activos</th>
                            <th scope="col" style="width: 15%">Estatus</th>
                            <th scope="col" class="text-end" style="width: 10%">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var agent in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center border me-3" style="width: 40px; height: 40px;">
                                            <span class="text-slate-dark fw-bold fs-7 font-monospace">@agent.FullName.Substring(0, Math.Min(2, agent.FullName.Length)).ToUpper()</span>
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-slate-dark">@agent.FullName</div>
                                            <small class="text-muted text-uppercase tracking-wider fs-9">Asesor Autorizado</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="text-slate-medium">@agent.Email</div>
                                    <small class="text-muted">@@@agent.UserName</small>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-slate-dark text-white rounded-0 px-3 py-2 font-monospace fs-7">@agent.ActivePropertiesCount</span>
                                </td>
                                <td>
                                    @if (agent.IsActive)
                                    {
                                        <span class="badge bg-success text-white rounded-0 px-2 py-1 fs-8">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger text-white rounded-0 px-2 py-1 fs-8">Inactivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form asp-action="ToggleAgentStatus" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="agentId" value="@agent.Id" />
                                        <input type="hidden" name="isActive" value="@(agent.IsActive ? "false" : "true")" />
                                        
                                        @if (agent.IsActive)
                                        {
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-0 px-3 py-1">Desactivar</button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-outline-success btn-sm rounded-0 px-3 py-1">Activar</button>
                                        }
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
