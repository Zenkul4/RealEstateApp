@using RealEstateApp.Core.Application.ViewModels.Agent
@model SaveAgentProfileViewModel
@{
    ViewData["Title"] = "Mi Perfil de Agente";
}

<div class="container px-4 mt-2 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light">
        <div>
            <h2 class="fw-bold tracking-tight text-slate-dark m-0">Mi Perfil Profesional</h2>
            <p class="text-muted m-0 fs-6">Actualice sus datos personales y fotografía de perfil.</p>
        </div>
        <div>
            <a asp-action="Index" class="btn-outline-slate">Volver al inicio</a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="architect-card p-4">
                <form asp-action="Profile" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="PhotoUrl" />

                    <div class="text-center mb-4">
                        @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                        {
                            <img src="@Model.PhotoUrl" alt="Foto de Perfil" class="rounded-circle border border-brass object-fit-cover mb-2" style="width: 110px; height: 110px;" />
                        }
                        else
                        {
                            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center border border-brass mb-2" style="width: 110px; height: 110px;">
                                <span class="text-slate-dark fw-bold fs-1 font-monospace">AG</span>
                            </div>
                        }
                        <p class="text-muted fs-8">Fotografía actual de perfil</p>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fs-8 text-uppercase tracking-wider fw-bold text-slate-dark">Nombre</label>
                            <input asp-for="FirstName" class="form-control rounded-0 border-slate" required />
                            <span asp-validation-for="FirstName" class="text-danger fs-8"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fs-8 text-uppercase tracking-wider fw-bold text-slate-dark">Apellido</label>
                            <input asp-for="LastName" class="form-control rounded-0 border-slate" required />
                            <span asp-validation-for="LastName" class="text-danger fs-8"></span>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fs-8 text-uppercase tracking-wider fw-bold text-slate-dark">Teléfono de Contacto</label>
                            <input asp-for="Phone" class="form-control rounded-0 border-slate" required />
                            <span asp-validation-for="Phone" class="text-danger fs-8"></span>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fs-8 text-uppercase tracking-wider fw-bold text-slate-dark">Nueva Foto de Perfil (Opcional)</label>
                            <input asp-for="Photo" type="file" accept="image/*" class="form-control rounded-0 border-slate" />
                            <small class="text-muted fs-9">Formatos permitidos: .jpg, .jpeg, .png. Si no selecciona un archivo, conservará su foto actual.</small>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top border-light d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn-outline-slate px-4 py-2 text-uppercase fs-8">Cancelar</a>
                        <button type="submit" class="btn-brass px-4 py-2 text-uppercase fs-8">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
