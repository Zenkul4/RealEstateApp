@model List<PropertyViewModel>
@{
    ViewData["Title"] = "Propiedades Disponibles";
    var favoriteIds = ViewBag.FavoriteIds as List<int> ?? new List<int>();
}

<!-- Hero Section -->
<div class="bg-slate-dark text-white py-5 mb-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
    <div class="container px-4 text-center py-3">
        <h1 class="display-5 fw-bold tracking-tight text-white mb-2 font-serif">Encuentre su <span class="text-brass">Hogar Ideal</span></h1>
        <p class="fs-5 text-muted max-w-xl mx-auto m-0">Explore propiedades exclusivas seleccionadas por nuestros asesores inmobiliarios autorizados.</p>
    </div>
</div>

<div class="container px-4">
    <div class="row g-4">
        <!-- Sidebar Filtros -->
        <div class="col-lg-3 col-md-4 col-sm-12">
            <div class="architect-card shadow-sm sticky-top" style="top: 20px; z-index: 10;">
                <div class="architect-header bg-light border-bottom border-light p-3">
                    <h5 class="fw-bold m-0 text-slate-dark text-uppercase tracking-wider fs-6">Filtros Avanzados</h5>
                </div>
                <div class="architect-body p-3">
                    <form method="get" asp-action="Index">
                        <div class="mb-3">
                            <label class="form-label fs-8 text-uppercase tracking-wide fw-bold">Tipo de Propiedad</label>
                            <select name="propertyTypeId" asp-items="ViewBag.PropertyTypes" class="form-select rounded-0 border-slate py-2">
                                <option value="">Todos los tipos</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fs-8 text-uppercase tracking-wide fw-bold">Precio Mínimo (DOP)</label>
                            <input type="number" name="minPrice" value="@ViewBag.SelectedMinPrice" class="form-control rounded-0 border-slate py-2" placeholder="Ej. 100000" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fs-8 text-uppercase tracking-wide fw-bold">Precio Máximo (DOP)</label>
                            <input type="number" name="maxPrice" value="@ViewBag.SelectedMaxPrice" class="form-control rounded-0 border-slate py-2" placeholder="Ej. 5000000" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fs-8 text-uppercase tracking-wide fw-bold">Habitaciones</label>
                            <input type="number" name="rooms" value="@ViewBag.SelectedRooms" class="form-control rounded-0 border-slate py-2" placeholder="Ej. 3" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fs-8 text-uppercase tracking-wide fw-bold">Baños</label>
                            <input type="number" name="bathrooms" value="@ViewBag.SelectedBathrooms" class="form-control rounded-0 border-slate py-2" placeholder="Ej. 2" />
                        </div>

                        <button type="submit" class="btn-brass w-100 py-2 mt-2">Buscar Inmuebles</button>
                        <a asp-action="Index" class="btn-outline-slate d-block text-center w-100 py-2 mt-2">Limpiar Filtros</a>
                    </form>
                </div>
            </div>
        </div>

        <!-- Resultados -->
        <div class="col-lg-9 col-md-8 col-sm-12">
            @if (Model == null || Model.Count == 0)
            {
                <div class="architect-card text-center py-5">
                    <p class="text-muted fs-5 mb-0">No se encontraron propiedades que coincidan con sus filtros.</p>
                    <p class="text-muted fs-6 mt-1">Pruebe limpiando o flexibilizando los criterios de búsqueda.</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var property in Model)
                    {
                        var hasImage = property.ImageUrls != null && property.ImageUrls.Count > 0;
                        var mainImage = hasImage ? property.ImageUrls[0] : "/images/placeholder.jpg";
                        var isFavorite = favoriteIds.Contains(property.Id);

                        <div class="col-lg-6 col-md-12 col-sm-12">
                            <div class="architect-card h-100 d-flex flex-column justify-content-between position-relative">
                                <div>
                                    <!-- Img wrapper -->
                                    <div class="position-relative overflow-hidden" style="height: 220px; background-color: #e2e8f0;">
                                        <img src="@mainImage" class="w-100 h-100" style="object-fit: cover; transition: transform 0.5s;" alt="Propiedad" />
                                        <span class="position-absolute top-0 start-0 bg-slate-dark text-white rounded-0 px-3 py-2 text-uppercase font-monospace fs-7 shadow-sm">CÓD: @property.Code</span>
                                        <span class="position-absolute bottom-0 end-0 bg-brass text-white rounded-0 px-3 py-1 text-uppercase fs-8 fw-bold">@property.SaleTypeName</span>

                                        <!-- Botón Favorito -->
                                        <form asp-action="ToggleFavorite" method="post" class="position-absolute top-0 end-0 m-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="propertyId" value="@property.Id" />
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                            <button type="submit" class="btn btn-white btn-sm shadow-sm rounded-circle d-flex align-items-center justify-content-center p-2" style="width: 38px; height: 38px; border: none;">
                                                @if (isFavorite)
                                                {
                                                    <span class="text-danger fs-5" style="line-height:1;">♥</span>
                                                }
                                                else
                                                {
                                                    <span class="text-secondary fs-5" style="line-height:1;">♡</span>
                                                }
                                            </button>
                                        </form>
                                    </div>

                                    <div class="architect-body">
                                        <h4 class="fw-bold text-slate-dark mb-1">@property.Price.ToString("C") DOP</h4>
                                        <h6 class="text-brass text-uppercase tracking-wider fs-7 mb-3">@property.PropertyTypeName</h6>
                                        <p class="text-muted fs-6 mb-4 text-truncate-2">@property.Description</p>
                                    </div>
                                </div>

                                <div class="mt-auto">
                                    <div class="row text-center bg-light g-0 py-2 border-top border-bottom border-light">
                                        <div class="col-4 border-end border-light">
                                            <small class="text-muted d-block text-uppercase fs-8 fw-semibold">Hab.</small>
                                            <span class="fw-bold text-slate-medium">@property.Rooms</span>
                                        </div>
                                        <div class="col-4 border-end border-light">
                                            <small class="text-muted d-block text-uppercase fs-8 fw-semibold">Baños</small>
                                            <span class="fw-bold text-slate-medium">@property.Bathrooms</span>
                                        </div>
                                        <div class="col-4">
                                            <small class="text-muted d-block text-uppercase fs-8 fw-semibold">Área</small>
                                            <span class="fw-bold text-slate-medium">@property.LandSize.ToString("N0") m²</span>
                                        </div>
                                    </div>
                                    <div class="architect-body py-3 text-center">
                                        <a asp-action="Details" asp-route-id="@property.Id" class="btn-outline-brass w-100 d-block text-center py-2 text-uppercase tracking-wider fs-7">Ver detalles</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
