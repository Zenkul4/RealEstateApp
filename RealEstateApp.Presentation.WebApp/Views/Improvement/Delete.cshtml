@model SaveImprovementViewModel
@{
    ViewData["Title"] = "Eliminar Mejora";
}

<div class="container px-4 mt-2">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 col-sm-12">
            <div class="architect-card mt-3">
                <div class="architect-header bg-danger text-white p-4">
                    <h4 class="fw-bold m-0 text-uppercase tracking-wider fs-5">Confirmar Eliminación</h4>
                    <p class="text-white-50 m-0 fs-6 mt-1">Esta acción es irreversible y afectará las relaciones del sistema.</p>
                </div>
                <div class="architect-body p-4 text-center">
                    <p class="fs-5 text-slate-dark mb-3">¿Está seguro que desea eliminar esta mejora?</p>
                    
                    <div class="alert alert-danger rounded-0 border-0 shadow-sm text-start p-3 mb-4">
                        <strong>Atención:</strong> Al eliminar esta mejora, se removerá automáticamente de todas las propiedades a las que está asociada. Las propiedades en sí mismas no serán eliminadas.
                    </div>
                    
                    <div class="border border-light p-3 bg-light mb-4 text-start">
                        <h4 class="fw-bold m-0">@Model.Name</h4>
                        <p class="text-muted m-0 mt-2">@Model.Description</p>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn-outline-slate">Cancelar</a>
                            <button type="submit" class="btn btn-danger px-4 py-2 rounded-0">Eliminar permanentemente</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
